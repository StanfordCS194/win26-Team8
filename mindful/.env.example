# Anthropic API Key for generating contextual questions with Claude
# Get your API key from https://console.anthropic.com/settings/keys
# In Expo, environment variables must be prefixed with EXPO_PUBLIC_
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API Key for sending friend unlock emails
# Get your API key from https://resend.com
EXPO_PUBLIC_RESEND_API_KEY=your_resend_api_key_here

{
  "manifest_version": 3,
  "name": "mindful",
  "version": "1.0.0",
  "description": "mindful web app packaged as a Chrome extension.",
  "action": {
    "default_title": "mindful",
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "tabs"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
